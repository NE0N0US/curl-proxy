{
	"name": "@ne0n0us/curl-proxy",
	"description": "Unauthenticated, non-caching, Node.js HTTP(S) proxy that supports batch requests and is driven by URL query.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/NE0N0US/curl-proxy.git"
	},
	"bugs": {
		"url": "https://github.com/NE0N0US/curl-proxy/issues"
	},
	"homepage": "https://curl-proxy.vercel.app/",
	"author": {
		"name": "NE0N0US",
		"url": "https://ne0n0us.github.io/"
	},
	"license": "Apache-2.0",
	"version": "0.3.0",
	"engines": {
		"node": ">=22.11.0"
	},
	"scripts": {
		"start": "vercel dev -Ll 0.0.0.0:2077",
		"prepublishOnly": "tsup --format esm,cjs --target es2024 --dts --tsconfig tsconfig.json --treeshake safest src/lib/proxy/index.ts && tsup --format esm --target es2024 --external ./index.js --clean false --tsconfig tsconfig.json src/cli.ts",
		"buildSea": "npm run prepublishOnly && tsup -d bin --format cjs --target es2024 dist/cli.js && node src/sea/preprocess.js && node --build-sea bin/sea-config.json && node src/sea/postprocess.js"
	},
	"dependencies": {
		"@jitl/quickjs-wasmfile-release-sync": "^0.32.0",
		"quickjs-emscripten-core": "^0.32.0",
		"quickjs-emscripten-sync": "^1.11.0",
		"undici": "^7.28.0"
	},
	"devDependencies": {
		"@types/node": "^24.0.0",
		"tsup": "^8.5.1",
		"vercel": "^56.1.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false,
	"type": "module",
	"types": "./dist/index.d.ts",
	"main": "./dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"module-sync": "./dist/index.js",
			"require": "./dist/index.cjs",
			"default": "./dist/index.js"
		}
	},
	"bin": "./dist/cli.js",
	"files": [
		"dist",
		"NOTICE"
	],
	"peerDependencies": {
		"@jitl/quickjs-wasmfile-release-sync": "^0.32.0",
		"quickjs-emscripten-core": "^0.32.0",
		"quickjs-emscripten-sync": "^1.11.0",
		"undici": "^7.28.0"
	},
	"keywords": [
		"node",
		"undici",
		"vercel",
		"quickjs",
		"wasm",
		"backend",
		"serverless",
		"app",
		"http",
		"https",
		"h2",
		"rest",
		"api",
		"fetch",
		"proxy",
		"orchestration",
		"url",
		"header",
		"cors",
		"retry",
		"timeout",
		"throttle",
		"stream",
		"transform",
		"eval",
		"vm"
	]
}
